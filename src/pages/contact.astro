---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Request Quote | Asphalt Maintenance Products | Shining Road Technology"
  description="Contact Shining Road Technology for cold mix asphalt, pavement sealcoat, and asphalt additive quotes. We respond within 24 hours."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-3">Contact Us</h1>
      <p class="text-xl text-gray-500 mb-12">We typically respond within 24 hours on business days.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Form -->
        <div>
          <h2 class="text-xl font-semibold mb-6">Send a Message</h2>
          <form 
            action="https://formspree.io/f/xgoqwgvd" 
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
              <input type="text" name="name" id="name" required
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" 
                     placeholder="John Smith" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
              <input type="email" name="email" id="email" required
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                     placeholder="john@company.com" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company / Organization</label>
              <input type="text" name="company" id="company"
                     class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                     placeholder="Your Company Ltd." />
            </div>
            <div>
              <label for="inquiry_type" class="block text-sm font-medium text-gray-700 mb-1">Inquiry Type</label>
              <select name="inquiry_type" id="inquiry_type"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors bg-white">
                <option value="">Select an option</option>
                <option value="product">Product Inquiry / Quote</option>
                <option value="cold-mix">Cold Mix Asphalt</option>
                <option value="sealcoat">Pavement Sealcoat</option>
                <option value="additives">Asphalt Additives</option>
                <option value="technical">Technical Support</option>
                <option value="distributor">Become a Distributor</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
              <textarea name="message" id="message" rows="5" required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"
                        placeholder="Tell us about your project, product needs, or questions..."></textarea>
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-green-700 transition-colors">
              Send Message
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            </button>
            <p class="text-xs text-gray-500 text-center">
              Your information is confidential. We'll never share your details with third parties.
            </p>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-xl font-semibold mb-6">Contact Information</h2>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Headquarters</h3>
                <p class="text-gray-600 mt-1">Shenyang, Liaoning Province, China</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Contact Person</h3>
                <p class="text-gray-600 mt-1">Mark — Sales & Technical Support</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Email</h3>
                <p class="text-gray-600 mt-1"><a href="mailto:lilei838025@gmail.com" class="text-primary hover:underline">lilei838025@gmail.com</a></p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Response Time</h3>
                <p class="text-gray-600 mt-1">We aim to respond within 24 hours during business days (Mon–Fri, UTC+8).</p>
              </div>
            </div>
          </div>

          <!-- Inquiry Types -->
          <div class="mt-8 space-y-4">
            <div class="p-5 bg-green-50 rounded-xl">
              <h3 class="font-semibold text-primary mb-1">Product Inquiries & Quotes</h3>
              <p class="text-sm text-gray-600">For pricing, samples, and technical data sheets. Please include estimated quantities and destination port.</p>
            </div>

            <div class="p-5 bg-amber-50 rounded-xl">
              <h3 class="font-semibold text-amber-700 mb-1">Technical Product Selection</h3>
              <p class="text-sm text-gray-600">For selecting cold patch grade, sealcoat system, additive dosage, and application guidance.</p>
            </div>

            <div class="p-5 bg-green-50 rounded-xl">
              <h3 class="font-semibold text-green-700 mb-1">Distributor Partnerships</h3>
              <p class="text-sm text-gray-600">Interested in becoming a distributor? Tell us about your market and we'll discuss territory and pricing.</p>
            </div>
          </div>

          <!-- Export Info -->
          <div class="mt-8 p-6 bg-gray-50 rounded-xl">
            <h3 class="font-semibold mb-3">Shipping & Logistics</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                FCL (Full Container Load) — 20' and 40' HC
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                LCL (Less than Container Load) — consolidated shipments
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Drums, IBC totes, bags, pails, and bulk shipments by product type
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Export documentation: CO, CI, PL, BL, MSDS, COA
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
