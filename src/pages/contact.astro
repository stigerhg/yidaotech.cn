---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact Us | Shenyang Shining Road Technology"
  description="Get in touch with us for product inquiries, quotes, and technical support."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">Contact Us</h1>
      <p class="section-subtitle">We'd love to hear from you. Send us a message and we'll respond promptly.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-12">
        <div>
          <h2 class="text-xl font-semibold mb-6">Send a Message</h2>
          <form 
            action="https://formspree.io/f/xgoqwgvd" 
            method="POST"
            class="space-y-4"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
              <input type="text" name="name" id="name" required
                     class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
              <input type="email" name="email" id="email" required
                     class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company</label>
              <input type="text" name="company" id="company"
                     class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
              <textarea name="message" id="message" rows="5" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center">
              Send Message
            </button>
          </form>
          <p class="text-xs text-gray-500 mt-4 text-center">
            Your information is safe with us. We'll never share your details.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold mb-6">Contact Information</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Address</h3>
                <p class="text-gray-600 mt-1">Shenyang, Liaoning Province, China</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Email</h3>
                <p class="text-gray-600 mt-1">Contact us via the form above</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-gray-900">Response Time</h3>
                <p class="text-gray-600 mt-1">We typically respond within 24 hours on business days</p>
              </div>
            </div>
          </div>

          <div class="mt-8 p-6 bg-gray-50 rounded-xl">
            <h3 class="font-semibold mb-2">Bulk Order Inquiries</h3>
            <p class="text-gray-600 text-sm">
              For bulk orders and distributor partnerships, please include your company details 
              and estimated order quantity in your message.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
