---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Road Sealant | Asphalt Crack Sealing & Pavement Maintenance"
  description="Professional-grade asphalt crack sealing and pavement maintenance products manufacturer from China."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-blue-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          Professional Asphalt Crack Sealing & Pavement Maintenance
        </h1>
        <p class="text-lg md:text-xl text-blue-100 mb-8 leading-relaxed">
          Your trusted source for road sealant, driveway patch, and pavement preservation products. 
          Serving contractors and distributors worldwide.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/products/" class="btn-primary bg-white !text-primary hover:!bg-gray-100">
            View Products
          </a>
          <a href="/contact/" class="btn-secondary !border-white !text-white hover:!bg-white hover:!text-primary">
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title">Why Choose Us</h2>
      <p class="section-subtitle">Professional-grade products backed by years of industry experience</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Quality Assured</h3>
          <p class="text-gray-600">Rigorous testing ensures every batch meets international standards for durability and performance.</p>
        </div>

        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Fast Delivery</h3>
          <p class="text-gray-600">Strategic location with efficient logistics network. Quick turnaround on orders of all sizes.</p>
        </div>

        <div class="card p-8 text-center">
          <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Expert Support</h3>
          <p class="text-gray-600">Technical guidance on product selection and application from experienced professionals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary text-white">
    <div class="max-w-3xl mx-auto text-center px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Don't Wait Until the Damage Gets Worse</h2>
      <p class="text-lg text-blue-100 mb-8">Get a quote for your project today — competitive pricing for bulk orders.</p>
      <a href="/contact/" class="btn-primary bg-white !text-primary hover:!bg-gray-100 text-lg px-8 py-4">
        Request a Quote
      </a>
    </div>
  </section>
</BaseLayout>
