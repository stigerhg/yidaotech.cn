---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout 
  title="Cold Mix Asphalt, Sealcoat & Asphalt Additives | Shining Road Technology"
  description="Buy cold mix asphalt, black and color pavement sealcoat, cold mix additive, asphalt recycling agent, and warm mix additive from Shining Road Technology."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-700 via-green-600 to-green-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
      <div class="max-w-3xl">
        <p class="text-green-200 text-sm md:text-base font-medium tracking-wide uppercase mb-4">Shenyang Shining Road Technology Co., Ltd.</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          Cold Mix Asphalt, Pavement Sealcoat & Asphalt Additives
        </h1>
        <p class="text-lg md:text-xl text-green-100 mb-8 leading-relaxed max-w-2xl">
          Focused pavement maintenance materials in three product families: cold mix asphalt, pavement sealcoat,
          and asphalt additives. Serving contractors, distributors, and asphalt plants worldwide.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/products/" class="inline-flex items-center px-6 py-3 bg-white text-primary font-semibold rounded-lg hover:bg-gray-100 transition-colors">
            View Products
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/contact/" class="inline-flex items-center px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-primary transition-colors">
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Our Solutions</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">Seven focused products across three pavement maintenance categories.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/products/category/cold-mix-asphalt/" class="group block p-8 bg-white rounded-xl border border-amber-200 hover:border-amber-400 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-amber-100 rounded-lg flex items-center justify-center mb-5 group-hover:bg-amber-500 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">Cold Mix Asphalt</h3>
          <p class="text-gray-600 text-sm">Standard all-weather cold patch and capsule pressure-sensitive cold patch for fast pothole and utility cut repair.</p>
        </a>

        <a href="/products/category/pavement-sealcoat/" class="group block p-8 bg-white rounded-xl border border-green-200 hover:border-green-400 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-5 group-hover:bg-green-600 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">Pavement Sealcoat</h3>
          <p class="text-gray-600 text-sm">Black coal tar and asphalt-emulsion sealcoat plus color anti-skid decorative coating for asphalt and concrete surfaces.</p>
        </a>

        <a href="/products/category/asphalt-additives/" class="group block p-8 bg-white rounded-xl border border-purple-200 hover:border-purple-400 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-5 group-hover:bg-purple-600 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">Asphalt Additives</h3>
          <p class="text-gray-600 text-sm">Cold mix additive, asphalt recycling agent, and warm mix additive for plants, recycling, and lower-temperature paving.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Why Contractors & Distributors Choose Us</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">International Standards</h3>
          <p class="text-gray-600">Products tested to ASTM, AASHTO, and EN specifications. Certificate of Analysis provided with every shipment.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Technical Support</h3>
          <p class="text-gray-600">Engineer-led support — product selection, application guidance, and on-site training available worldwide.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Global Logistics</h3>
          <p class="text-gray-600">Export to 30+ countries. FCL, LCL, and bulk shipments from major Chinese ports. Documentation support included.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center mb-12">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-2">Latest Updates</h2>
          <p class="text-gray-600">Industry insights, product news, and project updates</p>
        </div>
        <a href="/news/" class="text-primary font-medium hover:underline hidden md:inline-flex items-center gap-1">
          All articles <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestNews.map(article => (
          <a href={`/news/${article.slug}/`} class="group block">
            <article class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-primary hover:shadow-lg transition-all">
              <div class="p-6">
                <time class="text-sm text-gray-400">{article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                <h3 class="text-lg font-semibold mt-2 mb-3 group-hover:text-primary transition-colors line-clamp-2">{article.data.title}</h3>
                <p class="text-gray-600 text-sm line-clamp-3">{article.data.description}</p>
                {article.data.tags && article.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {article.data.tags.slice(0, 2).map(tag => (
                      <span class="text-xs font-medium text-primary bg-green-50 px-2 py-1 rounded-full">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>
      
      <div class="text-center mt-8 md:hidden">
        <a href="/news/" class="text-primary font-medium hover:underline">All articles &rarr;</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary text-white">
    <div class="max-w-3xl mx-auto text-center px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-lg text-green-100 mb-8 max-w-xl mx-auto">
        Whether you need samples, technical data, or a bulk export quote, our team can recommend the right product from the reorganized range.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="inline-flex items-center px-8 py-4 bg-white text-primary font-semibold rounded-lg hover:bg-gray-100 transition-colors text-lg">
          Request a Quote
        </a>
        <a href="/products/" class="inline-flex items-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-primary transition-colors text-lg">
          Browse Products
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
