---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocale, locales, localizedPath, t } from '../../i18n';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = getLocale(Astro.params.lang);
const copy = t(lang);
---

<BaseLayout lang={lang} title={copy.about.metaTitle} description={copy.about.metaDescription} canonicalURL={`https://yidaotech.xyz${localizedPath(lang, '/about/')}`}>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-3">{copy.about.title}</h1>
      <p class="text-xl text-gray-500 mb-12">{copy.about.subtitle}</p>
      <div class="prose prose-lg max-w-none">
        <p class="lead text-xl text-gray-700">{copy.about.lead}</p>
        {copy.about.sections.map(([title, body]) => (
          <>
            <h2>{title}</h2>
            <p>{body}</p>
          </>
        ))}
      </div>
      <div class="mt-12 text-center bg-gray-50 rounded-2xl p-10">
        <h3 class="text-2xl font-bold mb-4">{copy.about.ctaTitle}</h3>
        <p class="text-gray-600 mb-6 max-w-md mx-auto">{copy.about.ctaText}</p>
        <div class="flex justify-center gap-4">
          <a href={localizedPath(lang, '/contact/')} class="inline-flex items-center px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">{copy.actions.contactUs}</a>
          <a href={localizedPath(lang, '/products/')} class="inline-flex items-center px-6 py-3 border-2 border-primary text-primary font-semibold rounded-lg hover:bg-primary hover:text-white transition-colors">{copy.actions.browseProducts}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
