---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocale, locales, localizedPath, t } from '../../i18n';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = getLocale(Astro.params.lang);
const copy = t(lang);
---

<BaseLayout lang={lang} title={copy.contact.metaTitle} description={copy.contact.metaDescription} canonicalURL={`https://yidaotech.xyz${localizedPath(lang, '/contact/')}`}>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-3">{copy.contact.title}</h1>
      <p class="text-xl text-gray-500 mb-12">{copy.contact.subtitle}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-xl font-semibold mb-6">{copy.contact.formTitle}</h2>
          <form action="https://formspree.io/f/xgoqwgvd" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">{copy.contact.name} *</label>
              <input type="text" name="name" id="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">{copy.contact.email} *</label>
              <input type="email" name="email" id="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-gray-700 mb-1">{copy.contact.company}</label>
              <input type="text" name="company" id="company" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors" />
            </div>
            <div>
              <label for="inquiry_type" class="block text-sm font-medium text-gray-700 mb-1">{copy.contact.inquiryType}</label>
              <select name="inquiry_type" id="inquiry_type" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors bg-white">
                <option value="product">{copy.nav.products}</option>
                <option value="licensing">Technology Licensing</option>
                <option value="technical">Technical Support</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">{copy.contact.message} *</label>
              <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-colors"></textarea>
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">{copy.actions.sendMessage}</button>
            <p class="text-xs text-gray-500 text-center">{copy.contact.confidential}</p>
          </form>
        </div>

        <div>
          <h2 class="text-xl font-semibold mb-6">{copy.contact.infoTitle}</h2>
          <div class="space-y-6">
            <div><h3 class="font-medium text-gray-900">{copy.contact.headquarters}</h3><p class="text-gray-600 mt-1">Shenyang, Liaoning Province, China</p></div>
            <div><h3 class="font-medium text-gray-900">{copy.contact.contactPerson}</h3><p class="text-gray-600 mt-1">Mark — Sales & Technical Support</p></div>
            <div><h3 class="font-medium text-gray-900">{copy.contact.email}</h3><p class="text-gray-600 mt-1"><a href="mailto:lilei838025@gmail.com" class="text-primary hover:underline">lilei838025@gmail.com</a></p></div>
            <div><h3 class="font-medium text-gray-900">{copy.contact.responseTime}</h3><p class="text-gray-600 mt-1">{copy.contact.responseText}</p></div>
          </div>
          <div class="mt-8 p-6 bg-gray-50 rounded-xl">
            <h3 class="font-semibold mb-3">{copy.contact.shipping}</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li>FCL (20' and 40' HC)</li>
              <li>LCL consolidated shipments</li>
              <li>Bulk tanker for emulsified asphalt</li>
              <li>Export documentation: CO, CI, PL, BL, MSDS, COA</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
