---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLocale, localizedPath, nonDefaultLocales, t } from '../../../i18n';
import { absoluteUrl, metaDescription } from '../../../utils/seo';

export async function getStaticPaths() {
  const articles = await getCollection('news', ({ data }) => !data.draft);
  return nonDefaultLocales.flatMap(lang => articles.map(article => ({
    params: { lang, slug: article.slug },
    props: { article },
  })));
}

const lang = getLocale(Astro.params.lang);
const copy = t(lang);
const { article } = Astro.props;
const { title, date, description, image, tags } = article.data;
const { Content } = await article.render();
const url = `https://yidaotech.xyz${localizedPath(lang, `/news/${article.slug}/`)}`;
const optimizedDescription = metaDescription(description, 'Read the full article from Shining Road Technology.');

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": url,
  ...(image && { "image": absoluteUrl(image) }),
  "author": { "@type": "Person", "name": "Shining Road Technology" },
  "publisher": { "@type": "Organization", "name": "Shining Road Technology", "url": "https://yidaotech.xyz" },
  ...(tags?.length > 0 && { "keywords": tags.join(", ") })
};
---

<BaseLayout
  lang={lang}
  title={`${title} | Shining Road Technology`}
  description={optimizedDescription}
  canonicalURL={url}
  ogImage={image ? absoluteUrl(image) : undefined}
  ogType="article"
  schema={articleSchema}
>
  <article class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={localizedPath(lang, '/news/')} class="text-primary hover:underline text-sm mb-8 inline-block">&larr; {copy.actions.backToNews}</a>
      <header class="mt-4 mb-8">
        <time class="text-sm text-gray-500" datetime={date.toISOString()}>{date.toLocaleDateString(lang === 'en' ? 'en-US' : lang)}</time>
        <h1 class="text-3xl md:text-4xl font-bold mt-3 mb-4">{title}</h1>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">{tag}</span>)}
          </div>
        )}
      </header>
      {image && <img src={image} alt={`${title} article image`} class="w-full rounded-xl mb-8" loading="eager" />}
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
