---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLocale, locales, localizedPath, t, translateProduct } from '../../../i18n';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = getLocale(Astro.params.lang);
const copy = t(lang);
const allProducts = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  lang={lang}
  title={copy.productsPage.metaTitle}
  description={copy.productsPage.metaDescription}
  canonicalURL={`https://yidaotech.xyz${localizedPath(lang, '/products/')}`}
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">{copy.productsPage.title}</h1>
      <p class="section-subtitle">{copy.productsPage.subtitle}</p>

      {allProducts.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg mb-2">{copy.productsPage.empty}</p>
          <p>{copy.productsPage.emptyContact}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-8">
          {allProducts.map(product => {
            const data = translateProduct(lang, product);
            return (
              <a href={localizedPath(lang, `/products/${product.slug}/`)} class="card group">
                {data.image && (
                  <div class="aspect-video bg-gray-100 overflow-hidden">
                    <img src={data.image} alt={data.title}
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                  </div>
                )}
                <div class="p-6">
                  <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">
                    {data.category}
                  </span>
                  <h3 class="text-lg font-semibold mt-3 mb-2 group-hover:text-primary transition-colors">
                    {data.title}
                  </h3>
                  <p class="text-gray-600 text-sm line-clamp-2">{data.description}</p>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
