---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLocale, localizedPath, t, translateProduct } from '../../../../i18n';

export async function getStaticPaths() {
  const locales = ['ru', 'ar', 'id', 'zh'];
  const categories = ['cold-mix-asphalt', 'pavement-sealcoat', 'asphalt-additives'];
  return locales.flatMap(lang => categories.map(cat => ({ params: { lang, category: cat } })));
}

const lang = getLocale(Astro.params.lang);
const copy = t(lang);

const { category } = Astro.params;
const categoryMap: Record<string, string> = {
  'cold-mix-asphalt': 'Cold Mix Asphalt',
  'pavement-sealcoat': 'Pavement Sealcoat',
  'asphalt-additives': 'Asphalt Additives',
};
const displayNames: Record<string, string> = {
  'cold-mix-asphalt': 'Cold Mix Asphalt',
  'pavement-sealcoat': 'Pavement Sealcoat',
  'asphalt-additives': 'Asphalt Additives',
};
const shortNames: Record<string, string> = {
  'cold-mix-asphalt': 'Cold Mix',
  'pavement-sealcoat': 'Sealcoat',
  'asphalt-additives': 'Additives',
};
const catIcons: Record<string, string> = {
  'cold-mix-asphalt': 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  'pavement-sealcoat': 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  'asphalt-additives': 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
};
const catColors: Record<string, string> = {
  'cold-mix-asphalt': 'bg-amber-100 text-amber-600',
  'pavement-sealcoat': 'bg-blue-100 text-blue-600',
  'asphalt-additives': 'bg-purple-100 text-purple-600',
};
const catBorders: Record<string, string> = {
  'cold-mix-asphalt': 'border-amber-200',
  'pavement-sealcoat': 'border-blue-200',
  'asphalt-additives': 'border-purple-200',
};

const categoryName = categoryMap[category] || 'Cold Mix Asphalt';
const catProducts = (await getCollection('products', ({ data }) => !data.draft))
  .filter(p => p.data.category === categoryName)
  .sort((a, b) => a.data.order - b.data.order);
const displayName = displayNames[category] || categoryName;
const shortName = shortNames[category] || 'Products';
const icon = catIcons[category] || '';
const color = catColors[category] || 'bg-blue-100 text-blue-600';
const borderColor = catBorders[category] || 'border-blue-200';
---

<BaseLayout
  title={`${displayName} | Products | Shining Road Technology`}
  description={`Browse our ${displayName.toLowerCase()} products: ${catProducts.map(p => p.data.title).join(', ')}.`}
  canonicalURL={`https://yidaotech.xyz${localizedPath(lang, `/products/category/${category}/`)}`}
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={localizedPath(lang, '/products/')} class="text-primary hover:underline text-sm mb-8 inline-block">&larr; {copy.actions.backToProducts}</a>

      <div class="flex items-center gap-3 mb-8 pb-4 border-b-2 border-gray-100">
        <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${color}`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-gray-900">{displayName}</h1>
          <p class="text-gray-500 text-sm">{catProducts.length} product{catProducts.length !== 1 ? 's' : ''}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {catProducts.map(product => {
          const data = translateProduct(lang, product);
          return (
          <a href={localizedPath(lang, `/products/${product.slug}/`)} class={`card group border ${borderColor} hover:shadow-lg transition-all rounded-xl overflow-hidden bg-white`}>
            {data.image && (
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img src={data.image} alt={`${data.title} - ${categoryName} by Shining Road Technology`}
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">
                {data.category}
              </span>
              <h3 class="text-lg font-semibold mt-3 mb-2 group-hover:text-primary transition-colors">
                {data.title}
              </h3>
              <p class="text-gray-600 text-sm line-clamp-2">{data.description}</p>
            </div>
          </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
