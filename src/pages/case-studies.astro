---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Case Studies | Real-World Pavement Maintenance Results"
  description="See how our products perform in real-world applications. Road sealant and pavement maintenance case studies."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">Case Studies</h1>
      <p class="section-subtitle">Real-world results with our pavement maintenance products</p>

      <div class="mt-12 space-y-8">
        <div class="card p-8">
          <h2 class="text-xl font-semibold mb-4">Road Sealant Application — Municipal Project</h2>
          <p class="text-gray-600">
            Case study details will be added here. 
            This section showcases successful applications of our products in various settings.
          </p>
        </div>

        <div class="card p-8">
          <h2 class="text-xl font-semibold mb-4">Driveway Crack Repair — Residential</h2>
          <p class="text-gray-600">
            More case studies coming soon. Contact us to share your project results.
          </p>
        </div>

        <div class="text-center mt-12">
          <a href="/contact/" class="btn-primary">Share Your Project</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
