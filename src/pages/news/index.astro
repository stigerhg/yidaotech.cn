---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news', ({ data }) => !data.draft);
const sorted = allNews.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout 
  title="Pavement Maintenance News | Product Guides | Shining Road Technology"
  description="Read pavement maintenance guides, cold mix asphalt updates, crack sealing tips, and project news from Shining Road Technology."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">News & Articles</h1>
      <p class="section-subtitle">Stay updated with the latest from our team</p>

      {sorted.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg">Articles will be published soon. Check back later.</p>
        </div>
      ) : (
        <div class="space-y-8 mt-8">
          {sorted.map(article => (
            <a href={`/news/${article.slug}/`} class="card flex flex-col md:flex-row group">
              {article.data.image && (
                <div class="md:w-1/3 aspect-video md:aspect-auto bg-gray-100 overflow-hidden">
                  <img src={article.data.image} alt={`${article.data.title} article image`}
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
              )}
              <div class="p-6 flex-1">
                <time class="text-sm text-gray-500">
                  {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="text-xl font-semibold mt-2 mb-3 group-hover:text-primary transition-colors">
                  {article.data.title}
                </h3>
                <p class="text-gray-600 line-clamp-2">{article.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
