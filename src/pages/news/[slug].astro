---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl, metaDescription } from '../../utils/seo';

export async function getStaticPaths() {
  const articles = await getCollection('news', ({ data }) => !data.draft);
  return articles.map(a => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const { title, date, description, image, tags } = article.data;
const slug = article.slug;
const { Content } = await article.render();
const articleUrl = `https://yidaotech.xyz/news/${slug}/`;
const optimizedDescription = metaDescription(description, 'Read the full article from Shining Road Technology.');

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": articleUrl,
  ...(image && { "image": absoluteUrl(image) }),
  "author": {
    "@type": "Person",
    "name": "Shining Road Technology"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Shining Road Technology",
    "url": "https://yidaotech.xyz"
  },
  ...(tags?.length > 0 && { "keywords": tags.join(", ") })
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://yidaotech.xyz/" },
    { "@type": "ListItem", "position": 2, "name": "News", "item": "https://yidaotech.xyz/news/" },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
};

const schemas = [articleSchema, breadcrumbSchema];
---

<BaseLayout 
  title={`${title} | Shining Road Technology`} 
  description={optimizedDescription}
  canonicalURL={articleUrl}
  ogImage={image ? absoluteUrl(image) : undefined}
  ogType="article"
  schema={schemas}
>
  <article class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/news/" class="text-primary hover:underline text-sm mb-8 inline-block">&larr; Back to News</a>
      
      <header class="mt-4 mb-8">
        <time class="text-sm text-gray-500" datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="text-3xl md:text-4xl font-bold mt-3 mb-4">{title}</h1>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {image && (
        <img src={image} alt={`${title} article image`} class="w-full rounded-xl mb-8" loading="eager" />
      )}

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
