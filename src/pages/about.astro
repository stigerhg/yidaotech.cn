---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="About Us | Shenyang Shining Road Technology"
  description="Learn about our company, mission, and commitment to quality pavement maintenance products."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">About Us</h1>
      <p class="section-subtitle">Committed to quality and innovation in pavement maintenance</p>

      <div class="prose prose-lg max-w-none mt-12">
        <p>
          Shenyang Shining Road Technology is a professional manufacturer and supplier of road maintenance products, 
          specializing in asphalt crack sealing, pothole repair, and pavement preservation solutions.
        </p>
        
        <h2>Our Mission</h2>
        <p>
          To provide high-quality, cost-effective pavement maintenance products that extend road life 
          and reduce infrastructure maintenance costs for our customers worldwide.
        </p>

        <h2>Our Products</h2>
        <p>
          Our product line includes road sealant, driveway crack filler, asphalt repair materials, 
          and laboratory equipment. Each product undergoes rigorous quality control to meet 
          international standards.
        </p>

        <h2>Why Work With Us</h2>
        <ul>
          <li><strong>Experience:</strong> Years of industry expertise in road maintenance products</li>
          <li><strong>Quality:</strong> Rigorous testing and quality control at every stage</li>
          <li><strong>Service:</strong> Responsive support team ready to assist with your needs</li>
          <li><strong>Global Reach:</strong> Serving distributors and contractors internationally</li>
        </ul>

        <div class="not-prose mt-12 text-center">
          <a href="/contact/" class="btn-primary">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
