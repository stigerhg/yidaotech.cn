---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const categories = [...new Set(allProducts.map(p => p.data.category))];
---

<BaseLayout 
  title="Asphalt Maintenance Products | Crack Sealant & Cold Mix | Shining Road Technology"
  description="Browse asphalt crack sealants, cold mix pothole repair, emulsified asphalt, sealcoat, and production plants. Contact us for samples and export quotes."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">Our Products</h1>
      <p class="section-subtitle">Professional-grade pavement maintenance solutions for contractors and distributors</p>

      {allProducts.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg mb-2">Products will be added soon.</p>
          <p>Check back or <a href="/contact/" class="text-primary underline">contact us</a> for inquiries.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-8">
          {allProducts.map(product => (
            <a href={`/products/${product.slug}/`} class="card group">
              {product.data.image && (
                <div class="aspect-video bg-gray-100 overflow-hidden">
                  <img src={product.data.image} alt={`${product.data.title} - ${product.data.category} by Shining Road Technology`}
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
              )}
              <div class="p-6">
                <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">
                  {product.data.category}
                </span>
                <h3 class="text-lg font-semibold mt-3 mb-2 group-hover:text-primary transition-colors">
                  {product.data.title}
                </h3>
                <p class="text-gray-600 text-sm line-clamp-2">{product.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
