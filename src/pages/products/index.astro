---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const categoryOrder = ['Cold Mix Asphalt', 'Pavement Sealcoat', 'Asphalt Additives'];
const grouped = new Map<string, typeof allProducts>();
for (const cat of categoryOrder) grouped.set(cat, []);
for (const p of allProducts) {
  const cat = p.data.category;
  if (grouped.has(cat)) grouped.get(cat)!.push(p);
}
const categoryIcons: Record<string, string> = {
  'Cold Mix Asphalt': 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  'Pavement Sealcoat': 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  'Asphalt Additives': 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
};
const catColors: Record<string, string> = {
  'Cold Mix Asphalt': 'bg-amber-100 text-amber-600',
  'Pavement Sealcoat': 'bg-blue-100 text-blue-600',
  'Asphalt Additives': 'bg-purple-100 text-purple-600',
};
const catBorders: Record<string, string> = {
  'Cold Mix Asphalt': 'border-amber-200',
  'Pavement Sealcoat': 'border-blue-200',
  'Asphalt Additives': 'border-purple-200',
};
---

<BaseLayout 
  title="Pavement Maintenance Products | Cold Mix, Sealcoat & Asphalt Additives"
  description="Browse seven focused products: standard cold patch, capsule pressure cold patch, black sealcoat, color sealcoat, cold mix additive, recycling agent, and warm mix additive."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="section-title">Our Products</h1>
      <p class="section-subtitle">Three product families for road maintenance contractors, distributors, and asphalt plants</p>

      {allProducts.length === 0 ? (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg mb-2">Products will be added soon.</p>
          <p>Check back or <a href="/contact/" class="text-primary underline">contact us</a> for inquiries.</p>
        </div>
      ) : (
        categoryOrder.map(catKey => {
          const catProducts = grouped.get(catKey);
          if (!catProducts || catProducts.length === 0) return null;
          return (
            <div class="mb-16 last:mb-0">
              <div class="flex items-center gap-3 mb-8 pb-4 border-b-2 border-gray-100">
                <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${catColors[catKey]}`}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={categoryIcons[catKey]} />
                  </svg>
                </div>
                <h2 class="text-2xl font-bold text-gray-900">{catKey}</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {catProducts.map(product => (
                  <a href={`/products/${product.slug}/`} class={`card group border ${catBorders[catKey]} hover:shadow-lg transition-all rounded-xl overflow-hidden bg-white`}>
                    {product.data.image && (
                      <div class="aspect-video bg-gray-100 overflow-hidden">
                        <img src={product.data.image} alt={`${product.data.title} - ${catKey} by Shining Road Technology`}
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                      </div>
                    )}
                    <div class="p-6">
                      <span class="text-xs font-medium text-primary bg-blue-50 px-2 py-1 rounded-full">
                        {product.data.category}
                      </span>
                      <h3 class="text-lg font-semibold mt-3 mb-2 group-hover:text-primary transition-colors">
                        {product.data.title}
                      </h3>
                      <p class="text-gray-600 text-sm line-clamp-2">{product.data.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })
      )}
    </div>
  </section>
</BaseLayout>
